{
	"name": "remini-labs",
	"version": "0.10.0",
	"private": true,
	"description": "Remini Labs: A monorepo of experimental mini-apps developed by Tung Nguyen (redstrike), utilizing AI-assisted software development as the core approach.",
	"license": "MIT",
	"author": "Tung Nguyen <https://www.linkedin.com/in/redstrike/>",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"preview:cf": "wrangler dev",
		"deploy:cf": "wrangler deploy",
		"cf-typegen": "wrangler types",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:scripts": "tsc --noEmit -p scripts/tsconfig.json",
		"test:e2e": "playwright test",
		"fmt": "oxfmt && prettier --write \"**/*.svelte\"",
		"fmt:check": "oxfmt --check && prettier --check \"**/*.svelte\"",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"docs:fetch": "node scripts/fetch-docs.mts"
	},
	"dependencies": {
		"lightweight-charts": "^5.1.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260405.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/mcp": "^0.1.22",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.2",
		"@vitejs/plugin-basic-ssl": "^2.3.0",
		"autoprefixer": "^10.4.27",
		"bits-ui": "^2.17.2",
		"clsx": "^2.1.1",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"valibot": "^1.3.1",
		"vite": "^8.0.3",
		"vitest": "^4.1.2",
		"wrangler": "^4.80.0"
	},
	"engines": {
		"node": ">=24.14.0"
	}
}
