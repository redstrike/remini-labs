{
	"name": "remini-labs",
	"version": "0.5.0",
	"private": true,
	"description": "Remini Labs: A monorepo of experimental mini-apps developed by Tung Nguyen (redstrike), utilizing AI-assisted software development as the core approach.",
	"license": "MIT",
	"author": "Tung Nguyen <https://www.linkedin.com/in/redstrike/>",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"preview:cf": "wrangler dev",
		"deploy:cf": "wrangler deploy",
		"cf-typegen": "wrangler types",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test:e2e": "playwright test",
		"fmt": "oxfmt && prettier --write \"**/*.svelte\"",
		"fmt:check": "oxfmt --check && prettier --check \"**/*.svelte\"",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260301.1",
		"@internationalized/date": "^3.11.0",
		"@lucide/svelte": "^0.575.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/mcp": "^0.1.20",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.3",
		"@vitejs/plugin-basic-ssl": "^2.1.4",
		"autoprefixer": "^10.4.27",
		"bits-ui": "^2.16.2",
		"clsx": "^2.1.1",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.50.0",
		"postcss": "^8.5.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.6",
		"svelte-check": "^4.4.4",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"valibot": "^1.2.0",
		"vite": "^7.3.1",
		"wrangler": "^4.69.0"
	},
	"engines": {
		"node": ">=24.14.0"
	}
}
